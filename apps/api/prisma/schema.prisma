generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Photo {
  id        String   @id @default(uuid())
  url       String
  guestName String?  @map("guest_name")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("photos")
}